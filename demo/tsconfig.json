{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,

    /* Types & Paths */
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "react-keep-alive": ["../src/index.ts"],
      "react-keep-alive/router": ["../src/router/index.ts"]
    }
  },
  "include": [
    "App.tsx",
    "main.tsx",
    "pages/**/*",
    "vite.config.ts"
  ]
}
