{
  "name": "react-keep-alive-max",
  "version": "1.0.1",
  "description": "A Vue-like KeepAlive component for React 18/19 — cache component state, avoid re-renders on switch, boost performance.",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./router": {
      "types": "./dist/router.d.ts",
      "import": "./dist/router.esm.js",
      "require": "./dist/router.cjs.js"
    }
  },
  "scripts": {
    "build": "rollup -c rollup.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "demo": "npm run --prefix demo dev",
    "demo:install": "cd demo && npm install",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "keep-alive",
    "keepalive",
    "cache",
    "component",
    "state",
    "vue",
    "react-router",
    "performance"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.28.0",
    "rollup": "^4.28.0",
    "rollup-plugin-dts": "^6.1.0",
    "tslib": "^2.8.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "repository": {
    "type": "git",
    "url": ""
  }
}
